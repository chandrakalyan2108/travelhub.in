pipeline {
    agent any

    environment {
        TOMCAT_HOME = "/opt/tomcat9"
    }

    stages {

        stage('Checkout') {
            steps {
                git branch: 'main', url: 'https://github.com/chandrakalyan2108/travelhub.in.git'
            }
        }

        stage('Build') {
            steps {
                sh 'mvn clean package -DskipTests'
            }
        }

        stage('Deploy to Tomcat') {
            steps {
                sh '''
                sudo cp target/*.war /opt/tomcat9/webapps/ROOT.war
                sudo /opt/tomcat9/bin/shutdown.sh || true
                sudo /opt/tomcat9/bin/startup.sh
                '''
            }
        }
    }

    post {
        success {
            echo "✅ Deployment Successful"
        }
        failure {
            echo "❌ Build Failed"
        }
    }
}
