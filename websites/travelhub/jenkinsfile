pipeline {
    agent any
    environment {
        USERNAME    = "ubuntu"
        SERVER_IP   = credentials('travelhub-server-ip')
        APP_CONTEXT = "travelhub.in"
        APP_DIR     = "/home/ubuntu/travelhub"
        PROJECT_DIR = "/home/ubuntu/travelhub/websites/travelhub"
        REPO_URL    = "https://github.com/chandrakalyan2108/travelhub.in.git"
        TOMCAT_HOME = "/home/ubuntu/tomcat"
    }
    options {
        timestamps()
        disableConcurrentBuilds()
    }
    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }
        stage('Build & Deploy') {
            steps {
                sh '''
                ssh -o StrictHostKeyChecking=no ${USERNAME}@${SERVER_IP} "
                    set -ex
                    echo '===== SESSION INFO ====='
                    whoami
                    hostname -I
                    pwd

                    echo '===== UPDATE SOURCE ====='
                    if [ ! -d ${APP_DIR}/.git ]; then
                        rm -rf ${APP_DIR}
                        git clone ${REPO_URL} ${APP_DIR}
                    else
                        cd ${APP_DIR}
                        git fetch origin
                        git reset --hard origin/main
                    fi

                    echo '===== BUILD ====='
                    cd ${PROJECT_DIR}
                    mvn clean package -DskipTests

                    # Confirm the build actually produced a WAR before touching Tomcat
                    ls -la target/*.war
                    WAR_FILE=\\$(ls target/*.war | head -n1)
                    if [ -z \\\"\\$WAR_FILE\\\" ]; then
                        echo \\\"ERROR: WAR file not found after build\\\"
                        exit 1
                    fi
                    echo \\\"Built WAR: \\$WAR_FILE\\\"

                    echo '===== TOMCAT DIAGNOSTICS (before any checks) ====='
                    echo \\\"TOMCAT_HOME resolves to: ${TOMCAT_HOME}\\\"
                    readlink -f ${TOMCAT_HOME} || echo 'readlink failed - not a symlink or path issue'
                    ls -la ${TOMCAT_HOME} || echo \\\"Cannot list ${TOMCAT_HOME}\\\"
                    ls -la ${TOMCAT_HOME}/bin || echo \\\"Cannot list ${TOMCAT_HOME}/bin\\\"
                    stat ${TOMCAT_HOME}/bin/shutdown.sh 2>&1 || echo 'stat on shutdown.sh failed'
                    stat ${TOMCAT_HOME}/bin/startup.sh 2>&1 || echo 'stat on startup.sh failed'

                    # Confirm Tomcat webapps dir exists
                    if [ ! -d ${TOMCAT_HOME}/webapps ]; then
                        echo \\\"ERROR: ${TOMCAT_HOME}/webapps is not a directory on this server.\\\"
                        ls -la ${TOMCAT_HOME} || echo \\\"${TOMCAT_HOME} does not exist at all\\\"
                        exit 1
                    fi

                    # Ensure Tomcat scripts are executable (self-heal in case permissions were reset)
                    chmod +x ${TOMCAT_HOME}/bin/shutdown.sh ${TOMCAT_HOME}/bin/startup.sh || true

                    # Confirm bin scripts are executable
                    test -x ${TOMCAT_HOME}/bin/shutdown.sh || { echo \\\"ERROR: shutdown.sh not executable\\\"; exit 1; }
                    test -x ${TOMCAT_HOME}/bin/startup.sh  || { echo \\\"ERROR: startup.sh not executable\\\"; exit 1; }

                    echo '===== DEPLOY ====='
                    rm -rf ${TOMCAT_HOME}/webapps/${APP_CONTEXT}
                    rm -f ${TOMCAT_HOME}/webapps/${APP_CONTEXT}.war
                    cp \\$WAR_FILE ${TOMCAT_HOME}/webapps/${APP_CONTEXT}.war

                    # Stop Tomcat cleanly
                    ${TOMCAT_HOME}/bin/shutdown.sh || true
                    sleep 5

                    # Kill anything still bound to port 8080 (NOT a broad 'pkill -f catalina',
                    # which matches the deploy shell's own command line -- e.g. catalina.out in
                    # this very script -- and kills the SSH session running the pipeline itself)
                    sudo fuser -k 8080/tcp || true
                    sleep 2

                    # Start Tomcat
                    ${TOMCAT_HOME}/bin/startup.sh

                    # Wait for the app to actually respond instead of assuming success
                    echo 'Waiting for Tomcat to deploy the app...'
                    DEPLOYED=false
                    for i in \\$(seq 1 15); do
                        sleep 3
                        STATUS=\\$(curl -s -o /dev/null -w '%{http_code}' http://localhost:8080/${APP_CONTEXT}/ || echo '000')
                        echo \\\"Attempt \\$i: HTTP \\$STATUS\\\"
                        if [ \\\"\\$STATUS\\\" = \\\"200\\\" ] || [ \\\"\\$STATUS\\\" = \\\"302\\\" ]; then
                            DEPLOYED=true
                            break
                        fi
                    done

                    if [ \\\"\\$DEPLOYED\\\" != \\\"true\\\" ]; then
                        echo \\\"ERROR: App did not come up after deploy. Last 100 lines of catalina.out:\\\"
                        tail -100 ${TOMCAT_HOME}/logs/catalina.out
                        exit 1
                    fi
                    echo \\\"SUCCESS: ${APP_CONTEXT} is responding on port 8080\\\"
                    ls -lh ${TOMCAT_HOME}/webapps/
                "
                '''
            }
        }
    }
    post {
        success {
            echo "✅ Deployment Successful — check http://${SERVER_IP}:8080/${APP_CONTEXT}/"
        }
        failure {
            echo '❌ Deployment Failed'
        }
        always {
            cleanWs()
        }
    }
}
